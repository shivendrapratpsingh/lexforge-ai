# LexForge AI — environment template.
# Copy this file to `.env.local` (for `npm run dev`) and `.env` (for Prisma CLI),
# then fill in the values below. None of the .env* files are committed —
# they're listed in .gitignore.

# ── REQUIRED ────────────────────────────────────────────────────────────

# Postgres connection string. Free tier available at https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random 32+ char secret used by next-auth.
# Generate with:   openssl rand -base64 32
AUTH_SECRET="your-random-32-char-secret-here"

# Public URL of the app. http://localhost:3000 in dev, your Vercel URL in prod.
NEXTAUTH_URL="http://localhost:3000"

# Groq API key. Free tier at https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ── OPTIONAL ────────────────────────────────────────────────────────────

# next-auth v5 sometimes also reads AUTH_URL — leave it equal to NEXTAUTH_URL.
# AUTH_URL="http://localhost:3000"

# ── ADMIN ACCESS ────────────────────────────────────────────────────────
#
# The single platform admin is hard-coded in lib/admin.js as
#   ADMIN_EMAIL = 'pratapsinghshivendra21@gmail.com'
#
# To make YOURSELF the admin: edit lib/admin.js and replace that string
# with your own email, then register / log in with that email. The /admin
# route + Admin Console will appear automatically in the sidebar.
#
# Pro tier is granted in any of these ways:
#   1. Edit lib/admin.js -> ADMIN_EMAIL (always Pro).
#   2. Admin Console -> Users -> Upgrade (sets User.tier = 'pro' in the DB).
#   3. Admin Console -> Global Pro Promotion (everyone Pro for a window).
#   4. Admin Console -> Individual Pro Grants (per-email Pro for a window).
#   5. Admin Console -> System Settings -> Pro Enforcement OFF
#      (everyone gets Pro features for free).
