generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  name       String?
  email      String      @unique
  password   String?
  tier       String      @default("free")
  suspended  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  clients    Client[]
  courtDates CourtDate[]
  drafts     Draft[]
}

model Client {
  id            String             @id @default(cuid())
  userId        String
  name          String
  fatherName    String?
  age           String?
  gender        String?
  phone         String?
  email         String?
  address       String?
  city          String?
  district      String?
  state         String?            @default("Uttar Pradesh")
  pincode       String?
  aadhaarNumber String?
  photo         String?
  tags          String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments   ClientAttachment[]
  payments      ClientPayment[]
  courtDates    CourtDate[]
  drafts        Draft[]
}

model ClientAttachment {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  label     String?
  docType   String   @default("other")
  mimeType  String   @default("application/octet-stream")
  size      Int?
  data      String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientPayment {
  id          String   @id @default(cuid())
  clientId    String
  amount      Float
  date        DateTime
  mode        String   @default("cash")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Draft {
  id             String         @id @default(cuid())
  userId         String
  title          String
  content        String
  documentType   String
  status         String         @default("draft")
  templateData   Json?
  caseLaws       Json?
  legalReasoning String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  court          String?
  intakeMethod   String?        @default("form")
  language       String?        @default("english")
  sourceText     String?
  caseStatus     String?        @default("active")
  clientId       String?
  positivePoints String?
  amendmentNote  String?
  parentDraftId  String?
  courtDates     CourtDate[]
  client         Client?        @relation(fields: [clientId], references: [id])
  parentDraft    Draft?         @relation("DraftAmendments", fields: [parentDraftId], references: [id])
  amendments     Draft[]        @relation("DraftAmendments")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions       DraftVersion[]
}

model DraftVersion {
  id         String   @id @default(cuid())
  draftId    String
  version    Int
  content    String
  changeNote String?
  createdAt  DateTime @default(now())
  draft      Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model CourtDate {
  id         String   @id @default(cuid())
  userId     String
  draftId    String?
  clientId   String?
  title      String
  caseNumber String?
  date       DateTime
  type       String   @default("hearing")
  notes      String?
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client?  @relation(fields: [clientId], references: [id])
  draft      Draft?   @relation(fields: [draftId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Admin-set free-Pro window for EVERYONE. Only the most recent row is treated
// as the active window; the rest are history. Pro access is granted while
// NOW is between startsAt and endsAt (inclusive).
model GlobalPromo {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-set free-Pro grant for a specific email. The email does NOT need to
// belong to an existing user — if they sign up later, Pro kicks in during
// the window. Multiple non-overlapping rows per email are allowed.
model EmailPromo {
  id        String   @id @default(cuid())
  email     String
  startsAt  DateTime
  endsAt    DateTime
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// Singleton config row (id = "default") that the admin can toggle at runtime
// from the Admin Console.
//
//  proEnforcementEnabled = false  →  Pro features are unlocked for EVERYONE
//                                    (free users get full Pro experience,
//                                     no quota, no Pro-only locks).
//  proEnforcementEnabled = true   →  Free vs Pro distinction kicks in:
//                                    free users see basic generation,
//                                    capped at `freeDocsLimit` per month,
//                                    Pro-only doc types are locked.
model SystemConfig {
  id                    String   @id @default("default")
  proEnforcementEnabled Boolean  @default(false)
  freeDocsLimit         Int      @default(10)
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}
